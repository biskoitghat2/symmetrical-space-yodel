{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HesabFlow",
  "version": "2.0.12",

  "identifier": "com.hesabflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "HesabFlow",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "HesabFlow",
    "category": "Business",
    "shortDescription": "Smart Persian Accounting",
    "longDescription": "HesabFlow - A complete Persian accounting suite with invoicing, treasury, inventory, and workshop management.",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": ["en-US"]
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/biskoitghat2/symmetrical-space-yodel/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI0MDFDRkVCNDBCNkQ5OTUKUldTVjJiWkE2ODhCSkJxSXRHdUUyMzVNWFVwakFTT1NkYmtOenFzdGtBc04vYno3Y3I3bFlUWDYK"
    }
  }
}
